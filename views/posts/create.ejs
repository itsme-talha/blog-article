<div class="max-w-4xl mx-auto">
    <div class="mb-8 flex items-center justify-between">
        <div>
            <h1 class="text-3xl font-bold text-white mb-2 tracking-tight">Draft New Article</h1>
            <p class="text-light-grey text-sm">Publish a new post to the Blog-Article feed.</p>
        </div>
        <a href="/dashboard" class="text-sm font-medium text-light-grey hover:text-white transition-colors flex items-center gap-2">
            <span class="material-icons text-[18px]">arrow_back</span> Back to Dashboard
        </a>
    </div>

    <div class="bg-dark-slate/30 border border-white/5 rounded-2xl p-8 shadow-2xl relative overflow-hidden">
        <div class="absolute top-0 right-0 w-64 h-64 bg-primary/5 rounded-full blur-[80px] -z-10 pointer-events-none"></div>

        <form action="/posts" method="POST" enctype="multipart/form-data" class="space-y-6" id="postForm">
            
            <div>
                <label class="block text-sm font-bold text-white mb-2">Article Title</label>
                <input type="text" name="title" required 
                    class="w-full bg-dark-deep border border-white/10 text-white rounded-lg px-4 py-3 focus:outline-none focus:border-primary transition-colors placeholder-light-grey/30"
                    placeholder="Enter an engaging title...">
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-sm font-bold text-white mb-2">Tags (Comma separated)</label>
                    <input type="text" name="tags" 
                        class="w-full bg-dark-deep border border-white/10 text-white rounded-lg px-4 py-3 focus:outline-none focus:border-primary transition-colors placeholder-light-grey/30"
                        placeholder="Technology, Design, UX">
                </div>

                <div>
                    <label class="block text-sm font-bold text-white mb-2">Featured Image</label>
                    <input type="file" name="image" accept="image/*"
                        class="w-full bg-dark-deep border border-white/10 text-light-grey rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary transition-colors file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-bold file:bg-primary/10 file:text-primary hover:file:bg-primary/20">
                </div>
            </div>

            <div>
                <label class="block text-sm font-bold text-white mb-2">Article Content</label>
                <input type="hidden" name="content" id="hiddenContent">
                
                <div id="editor-container" class="bg-dark-deep text-white rounded-b-lg"></div>
            </div>

            <div class="pt-4 flex justify-end">
                <button type="submit" class="bg-primary text-dark-deep font-bold px-8 py-3 rounded-lg hover:bg-white transition-colors flex items-center gap-2 shadow-lg shadow-primary/20">
                    <span class="material-icons text-[18px]">publish</span> Publish Article
                </button>
            </div>
        </form>
    </div>
</div>

<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
<script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>

<style>
    .ql-toolbar.ql-snow {
        border: 1px solid rgba(255,255,255,0.1);
        background: rgba(255,255,255,0.02);
        border-radius: 0.5rem 0.5rem 0 0;
    }
    .ql-container.ql-snow {
        border: 1px solid rgba(255,255,255,0.1);
        border-top: none;
        min-height: 250px;
        font-family: 'Space Grotesk', sans-serif;
        font-size: 1rem;
    }
    .ql-editor { color: white; }
    .ql-editor.ql-blank::before { color: rgba(197, 211, 216, 0.3); font-style: normal; }
    .ql-snow .ql-stroke { stroke: #C5D3D8; }
    .ql-snow .ql-fill { fill: #C5D3D8; }
    .ql-snow .ql-picker { color: #C5D3D8; }
    .ql-snow .ql-picker-options { background-color: #010102; border-color: rgba(255,255,255,0.1); }
</style>

<script>
    var quill = new Quill('#editor-container', {
        theme: 'snow',
        placeholder: 'Write your masterpiece here...',
        modules: {
            toolbar: [
                [{ 'header': [1, 2, 3, false] }],
                ['bold', 'italic', 'underline', 'strike', 'blockquote', 'code-block'],
                [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                ['link', 'image']
            ]
        }
    });

    // Copy Quill content to hidden input before form submits
    document.getElementById('postForm').onsubmit = function() {
        var content = document.querySelector('input[name=content]');
        content.value = quill.root.innerHTML;
        
        if(quill.getText().trim().length === 0) {
            alert('Article content cannot be empty!');
            return false;
        }
    };
</script>