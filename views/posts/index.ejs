<div class="max-w-7xl mx-auto px-6 lg:px-8 py-10">

    <div class="flex items-center gap-4 overflow-x-auto pb-6 scrollbar-hide mb-8">
        <button class="px-6 py-2 rounded-full bg-primary text-dark-deep font-bold text-sm whitespace-nowrap">All Posts</button>
        <button class="px-6 py-2 rounded-full bg-white/5 text-light-grey hover:bg-white/10 hover:text-white transition-all text-sm font-medium whitespace-nowrap border border-white/5">Software Engineering</button>
        <button class="px-6 py-2 rounded-full bg-white/5 text-light-grey hover:bg-white/10 hover:text-white transition-all text-sm font-medium whitespace-nowrap border border-white/5">UI/UX Design</button>
        <button class="px-6 py-2 rounded-full bg-white/5 text-light-grey hover:bg-white/10 hover:text-white transition-all text-sm font-medium whitespace-nowrap border border-white/5">Web Technologies</button>
    </div>

    <% if (posts.length > 0) { %>
        <div class="relative w-full h-[500px] rounded-[2rem] overflow-hidden mb-16 group cursor-pointer shadow-2xl">
            <% if (posts[0].image) { %>
                <img src="<%= posts[0].image.startsWith('http') ? posts[0].image : '/uploads/' + posts[0].image %>" alt="Featured" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
            <% } else { %>
                <div class="absolute inset-0 w-full h-full bg-dark-slate flex items-center justify-center group-hover:scale-105 transition-transform duration-700">
                    <span class="material-icons text-9xl text-white/5">article</span>
                </div>
            <% } %>
            <div class="absolute inset-0 bg-gradient-to-t from-dark-deep via-dark-deep/60 to-transparent"></div>
            
            <div class="absolute bottom-0 left-0 p-10 md:p-16 w-full md:w-3/4">
                <% if (posts[0].tags && posts[0].tags.length > 0) { %>
                    <span class="inline-block px-3 py-1 rounded-full bg-primary/20 text-primary border border-primary/30 text-xs font-bold uppercase tracking-wider mb-4 backdrop-blur-sm"><%= posts[0].tags[0] %></span>
                <% } %>
                <h1 class="text-3xl md:text-5xl font-bold text-white leading-tight mb-4 group-hover:text-primary transition-colors duration-300"><%= posts[0].title %></h1>
                <p class="text-light-grey text-sm md:text-base line-clamp-2 mb-6"><%= posts[0].content.replace(/<[^>]+>/g, '') %></p>
                
                <div class="flex items-center gap-4 text-sm">
                    <div class="flex items-center gap-2">
                        <div class="w-8 h-8 rounded-full bg-primary text-dark-deep flex items-center justify-center font-bold text-xs"><%= posts[0].author.name.charAt(0) %></div>
                        <span class="text-white font-medium"><%= posts[0].author.name %></span>
                    </div>
                    <span class="text-light-grey/50">•</span>
                    <span class="text-light-grey"><%= posts[0].createdAt.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                </div>
            </div>
            <a href="/posts/<%= posts[0]._id %>" class="absolute inset-0 z-10"></a>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
            <div class="lg:col-span-2">
                <h2 class="text-2xl font-bold text-white mb-8 flex items-center gap-2"><span class="w-2 h-8 bg-primary rounded-full"></span> Latest Articles</h2>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <% posts.slice(1).forEach(post => { %>
                        <div class="group cursor-pointer">
                            <div class="w-full h-56 rounded-2xl overflow-hidden mb-5 relative bg-dark-slate">
                                <% if (post.image) { %>
                                    <img src="<%= post.image.startsWith('http') ? post.image : '/uploads/' + post.image %>" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                                <% } else { %>
                                    <div class="w-full h-full flex items-center justify-center text-white/5 group-hover:scale-110 transition-transform duration-700">
                                        <span class="material-icons text-7xl">article</span>
                                    </div>
                                <% } %>
                                <div class="absolute inset-0 bg-dark-deep/10 group-hover:bg-transparent transition-colors"></div>
                            </div>

                            <% if (post.tags && post.tags.length > 0) { %>
                                <p class="text-primary text-xs font-bold uppercase tracking-wider mb-2"><%= post.tags[0] %></p>
                            <% } %>
                            <h3 class="text-xl font-bold text-white mb-2 group-hover:text-primary transition-colors line-clamp-2"><%= post.title %></h3>
                            <p class="text-light-grey/70 text-sm mb-4 line-clamp-2"><%= post.content.replace(/<[^>]+>/g, '') %></p>
                            <a href="/posts/<%= post._id %>" class="text-sm font-bold text-white group-hover:text-primary flex items-center gap-1 transition-colors">Read Article <span class="material-icons text-[16px]">arrow_forward</span></a>
                            <a href="/posts/<%= post._id %>" class="absolute inset-0 hidden"></a>
                        </div>
                    <% }) %>
                </div>
            </div>

            <div class="space-y-12">
                <div>
                    <h2 class="text-xl font-bold text-white mb-6 border-b border-white/10 pb-4">Most Popular</h2>
                    <div class="space-y-6">
                        <% posts.slice(0, 3).forEach((post, index) => { %>
                            <a href="/posts/<%= post._id %>" class="flex items-start gap-4 group">
                                <span class="text-4xl font-black text-white/10 group-hover:text-primary/20 transition-colors">0<%= index + 1 %></span>
                                <div>
                                    <h4 class="text-white font-semibold leading-snug group-hover:text-primary transition-colors line-clamp-2"><%= post.title %></h4>
                                    <p class="text-xs text-light-grey/50 mt-1"><%= post.createdAt.toLocaleDateString() %></p>
                                </div>
                            </a>
                        <% }) %>
                    </div>
                </div>

                <div class="bg-gradient-to-br from-primary/20 to-transparent border border-primary/20 rounded-2xl p-6 text-center">
                    <span class="material-icons text-4xl text-primary mb-3">auto_awesome</span>
                    <h3 class="text-lg font-bold text-white mb-2">Master Web Tech</h3>
                    <p class="text-sm text-light-grey mb-4">Learn to build high-ticket applications with our advanced tutorials.</p>
                    <a href="/posts" class="block w-full py-2 bg-primary text-dark-deep font-bold rounded-lg text-sm hover:bg-white transition-colors">Explore All</a>
                </div>
            </div>
        </div>
    <% } else { %>
        <div class="py-20 text-center">
            <div class="w-24 h-24 bg-white/5 rounded-full flex items-center justify-center mx-auto mb-6">
                <span class="material-icons text-primary text-4xl">inbox</span>
            </div>
            <h2 class="text-3xl font-bold text-white mb-2">No Articles Found</h2>
            <p class="text-light-grey">The editorial team is working on something awesome. Check back soon!</p>
        </div>
    <% } %>
</div>

<div class="border-t border-white/5 mt-16 py-24 bg-gradient-to-b from-dark-slate/20 to-transparent">
    <div class="max-w-4xl mx-auto px-6 text-center">
        <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-6 border border-primary/20">
            <span class="material-icons text-primary text-3xl">forum</span>
        </div>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Join the Developer Community</h2>
        <p class="text-light-grey mb-10 max-w-2xl mx-auto text-lg">Create a free account to interact with articles, save your favorite tech tutorials, and join discussions with other engineers.</p>
        <div class="flex flex-col sm:flex-row justify-center gap-4">
            <a href="/auth/register" class="bg-primary text-dark-deep font-bold px-8 py-3.5 rounded-full hover:bg-white transition-colors shadow-lg shadow-primary/20">Create Free Account</a>
            <a href="/auth/login" class="bg-transparent text-white border border-white/20 font-bold px-8 py-3.5 rounded-full hover:bg-white/10 transition-colors">Log In</a>
        </div>
    </div>
</div>