<div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-10 gap-4">
    <div>
        <h1 class="text-3xl font-bold text-white mb-1 tracking-tight">System Overview</h1>
        <p class="text-sm text-light-grey">Welcome back to the developer console. Here's what's happening.</p>
    </div>
    <a href="/posts/create/new" class="bg-primary text-dark-deep px-6 py-2.5 rounded-lg font-bold hover:bg-white transition-colors flex items-center gap-2 shadow-lg shadow-primary/20">
        <span class="material-icons text-sm">add</span> Create New Post
    </a>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
    <div class="bg-dark-slate/30 border border-white/5 rounded-2xl p-6 relative overflow-hidden group">
        <div class="absolute top-0 right-0 w-32 h-32 bg-primary/5 rounded-bl-[100px] -z-10 group-hover:bg-primary/10 transition-colors"></div>
        <div class="flex justify-between items-start mb-4">
            <div class="w-12 h-12 bg-white/5 rounded-xl flex items-center justify-center text-light-grey">
                <span class="material-icons">article</span>
            </div>
            <span class="text-xs font-bold text-primary bg-primary/10 px-2 py-1 rounded-md">+12%</span>
        </div>
        <h3 class="text-3xl font-black text-white mb-1"><%= posts ? posts.length : 0 %></h3>
        <p class="text-sm text-light-grey font-medium">Total Published Posts</p>
    </div>

    <div class="bg-dark-slate/30 border border-white/5 rounded-2xl p-6 relative overflow-hidden group">
        <div class="absolute top-0 right-0 w-32 h-32 bg-[#3B82F6]/5 rounded-bl-[100px] -z-10 group-hover:bg-[#3B82F6]/10 transition-colors"></div>
        <div class="flex justify-between items-start mb-4">
            <div class="w-12 h-12 bg-white/5 rounded-xl flex items-center justify-center text-light-grey">
                <span class="material-icons">visibility</span>
            </div>
            <span class="text-xs font-bold text-[#3B82F6] bg-[#3B82F6]/10 px-2 py-1 rounded-md">+24%</span>
        </div>
        <h3 class="text-3xl font-black text-white mb-1">12.4k</h3>
        <p class="text-sm text-light-grey font-medium">Monthly Page Views</p>
    </div>

    <div class="bg-dark-slate/30 border border-white/5 rounded-2xl p-6 relative overflow-hidden group">
        <div class="absolute top-0 right-0 w-32 h-32 bg-[#8B5CF6]/5 rounded-bl-[100px] -z-10 group-hover:bg-[#8B5CF6]/10 transition-colors"></div>
        <div class="flex justify-between items-start mb-4">
            <div class="w-12 h-12 bg-white/5 rounded-xl flex items-center justify-center text-light-grey">
                <span class="material-icons">people</span>
            </div>
        </div>
        <h3 class="text-3xl font-black text-white mb-1">1,248</h3>
        <p class="text-sm text-light-grey font-medium">Registered Community Users</p>
    </div>
</div>

<div class="bg-dark-slate/30 border border-white/5 rounded-2xl overflow-hidden">
    <div class="p-6 border-b border-white/5 flex justify-between items-center">
        <h2 class="text-lg font-bold text-white">Content Management</h2>
        <button class="text-sm text-primary hover:underline font-medium">View All</button>
    </div>
    
    <div class="overflow-x-auto">
        <table class="w-full text-left text-sm text-light-grey">
            <thead class="bg-white/5 text-xs uppercase font-semibold text-light-grey/60 border-b border-white/5">
                <tr>
                    <th scope="col" class="px-6 py-4">Article Title</th>
                    <th scope="col" class="px-6 py-4">Category</th>
                    <th scope="col" class="px-6 py-4">Publish Date</th>
                    <th scope="col" class="px-6 py-4 text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-white/5">
                <% if (posts && posts.length > 0) { %>
                    <% posts.slice(0, 5).forEach(post => { %>
                        <tr class="hover:bg-white/[0.02] transition-colors">
                            <td class="px-6 py-4">
                                <a href="/posts/<%= post._id %>" target="_blank" class="font-bold text-white hover:text-primary transition-colors line-clamp-1"><%= post.title %></a>
                            </td>
                            <td class="px-6 py-4">
                                <% if (post.tags && post.tags.length > 0) { %>
                                    <span class="px-2 py-1 bg-white/5 rounded text-xs"><%= post.tags[0] %></span>
                                <% } else { %>
                                    <span class="text-light-grey/40">Uncategorized</span>
                                <% } %>
                            </td>
                            <td class="px-6 py-4 text-light-grey/70">
                                <%= post.createdAt.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                            </td>
                            <td class="px-6 py-4 flex justify-end gap-3">
                                <a href="/posts/<%= post._id %>/edit" class="text-light-grey hover:text-primary transition-colors" title="Edit">
                                    <span class="material-icons text-[20px]">edit</span>
                                </a>
                                <form action="/posts/<%= post._id %>?_method=DELETE" method="POST" class="inline" onsubmit="return confirm('Are you sure you want to delete this post?');">
                                    <button type="submit" class="text-light-grey hover:text-red-500 transition-colors" title="Delete">
                                        <span class="material-icons text-[20px]">delete</span>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="4" class="px-6 py-8 text-center text-light-grey/50">
                            No articles found. Click "Create New Post" to get started.
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>